#!/bin/bash

set -e

SCRIPT_DIR="$( cd "$( dirname "$( realpath "${BASH_SOURCE[0]}" )" )" && pwd )"

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "Docker is not running. Starting Docker Desktop App..."
    
    # Start Docker Desktop on macOS
    if [[ "$OSTYPE" == "darwin"* ]]; then
        open -a Docker
    else
        echo "Please start Docker manually on your system"
        exit 1
    fi

    echo "Waiting for Docker to start (this may take a minute)..."
    max_wait=60
    waited=0
    until docker info > /dev/null 2>&1; do
        if [ $waited -ge $max_wait ]; then
            echo -e "\nError: Docker did not start within $max_wait seconds"
            exit 1
        fi
        echo -n "."
        sleep 2
        waited=$((waited + 2))
    done
    echo -e "\nDocker is ready!"
fi

# Auto-setup on first run (SSH keys, dirs, .env, image)
source "$SCRIPT_DIR/setup.sh"
run_setup

# Capture current directory before changing to script directory
CURRENT_DIR=$(pwd)
WINDOW_COUNT=1
WINDOW_DELAY=0.5
CONTINUE_SESSION=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--delay)
            WINDOW_DELAY="$2"
            shift 2
            ;;
        -c|--continue)
            CONTINUE_SESSION=true
            shift
            ;;
        -h|--help)
            echo "Usage: ocd [DIRECTORY] [WINDOW_COUNT] [--delay SECONDS] [-c]"
            echo "  DIRECTORY    Project directory (default: current)"
            echo "  WINDOW_COUNT Number of terminal windows to open (default: 1)"
            echo "  --delay      Seconds to wait between opening windows (default: 0.5)"
            echo "  -c/--continue Continue last session"
            exit 0
            ;;
        *)
            if [[ "$1" =~ ^[0-9]+$ ]]; then
                WINDOW_COUNT=$1
                shift
            elif [ -d "$1" ]; then
                CURRENT_DIR=$(realpath "$1")
                shift
            else
                break
            fi
            ;;
    esac
done

# Function to run a single OpenCode container
run_opencode_container() {
    local WORKDIR="$1"
    cd "$SCRIPT_DIR"
    
    # Calculate the working directory inside Docker
    PROJECTS_DIR="$HOME/Projects"
    if [[ "$WORKDIR" == "$PROJECTS_DIR"* ]]; then
        RELATIVE_PATH="${WORKDIR#$PROJECTS_DIR}"
        RELATIVE_PATH="${RELATIVE_PATH#/}"
        if [ -z "$RELATIVE_PATH" ]; then
            DOCKER_WORKDIR="/root/Projects"
        else
            DOCKER_WORKDIR="/root/Projects/$RELATIVE_PATH"
        fi
    else
        DOCKER_WORKDIR="/root/Projects"
        echo "Warning: Path $WORKDIR is outside ~/Projects, starting in /root/Projects"
    fi

    echo "Starting OpenCode sandbox in $DOCKER_WORKDIR..."

    # Forward terminal environment variables for proper mouse reporting and scrolling
    if command -v stty > /dev/null 2>&1; then
        TERM_SIZE=$(stty size 2>/dev/null || echo "24 80")
        export LINES=$(echo $TERM_SIZE | cut -d' ' -f1)
        export COLUMNS=$(echo $TERM_SIZE | cut -d' ' -f2)
    fi

    export TERM=${TERM:-xterm-256color}

    # Load .env to get INTERNET_ACCESS and SANDBOX_ENABLED
    if [ -f "$SCRIPT_DIR/.env" ]; then
        set -a
        source <(grep -v '^#' "$SCRIPT_DIR/.env" | grep -v '^$' | sed 's/^/export /')
        set +a
    fi

    # Set NETWORK_MODE based on INTERNET_ACCESS
    if [ "${INTERNET_ACCESS:-true}" = "false" ]; then
        export NETWORK_MODE=bridge
    else
        export NETWORK_MODE=host
    fi

    docker compose run --rm --service-ports -w "$DOCKER_WORKDIR" \
        -e TERM \
        -e COLUMNS \
        -e LINES \
        -e TOOL=opencode \
        -e SSH_ENABLED=true \
        llm_docker "$@"
}

# If WINDOW_COUNT > 1 and we're on macOS with iTerm2, open multiple windows
# If WINDOW_COUNT > 1 and we're on macOS, use pro_llm multi-window layout
if [ "$WINDOW_COUNT" -gt 1 ] && [[ "$OSTYPE" == "darwin"* ]]; then
    SLOT_MODE="new"
    [ "$CONTINUE_SESSION" = true ] && SLOT_MODE="restore"
    echo "Opening $WINDOW_COUNT terminal windows ($SLOT_MODE mode)..."
    osascript "$SCRIPT_DIR/pro_llm.applescript" "$SCRIPT_DIR/ocd" "$WINDOW_COUNT" "$CURRENT_DIR" "$SLOT_MODE"
    exit 0
fi

# Single window - run directly
run_opencode_container "$CURRENT_DIR" "$@"
