# OpenCode/Claude Sandbox Environment Variables

# API Keys (add your own)
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=

# Default working directory inside container
WORKSPACE_DIR=/Projects

# Environment mode (development, production)
NODE_ENV=development

# Sandbox settings
SANDBOX_ENABLED=false
INTERNET_ACCESS=true
SSH_ENABLED=true

# ============================================
# Claude Code Settings
# ============================================

# Root bypass (Claude Code refuses bypass as root)
IS_SANDBOX=1
CLAUDE_CODE_BUBBLEWRAP=1

# Maximum number of tokens Claude Code can return in outputs
CLAUDE_CODE_MAX_OUTPUT_TOKENS=48000

# Default model to use for Claude Code
ANTHROPIC_MODEL=claude-sonnet-4-6

# Advanced: Specify model for subagents
#CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-4-5
