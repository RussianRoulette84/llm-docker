_dp_init_theme() {
    C7=$'\033[38;5;177m'; C8=$'\033[38;5;213m'
    RESET=$'\033[0m'; BOLD=$'\033[1m'; DIM=$'\033[2m'
    LIGHT_GREEN=$'\033[38;5;82m'; RED=$'\033[31m'
    YELLOW=$'\033[33m'
    LIGHT_ORANGE=$'\033[38;5;214m'
    DIM_PINK="${C8}${DIM}"
    TREE_MID="│  "; TREE_SECTION="├"
    accent_color="${C7}"
    SHAZAMP_GRADIENT=(
        $'\033[38;5;177m' $'\033[38;5;176m' $'\033[38;5;175m' $'\033[38;5;174m'
        $'\033[38;5;173m' $'\033[38;5;172m' $'\033[38;5;171m' $'\033[38;5;170m'
        $'\033[38;5;169m' $'\033[38;5;168m' $'\033[38;5;208m' $'\033[38;5;209m'
        $'\033[38;5;210m' $'\033[38;5;211m' $'\033[38;5;212m' $'\033[38;5;213m'
    )
}

_dp_section() {
    printf "\n%b%s%b %b%s%b\n" "$accent_color" "$TREE_SECTION" "$RESET" "$LIGHT_ORANGE" "$1" "$RESET"
}

_dp_banner() {
    local g_len=${#SHAZAMP_GRADIENT[@]} i=0
    local lines=(
        ' ██████╗ ███████╗██╗   ██╗      ██████╗  █████╗  ██████╗██╗  ██╗'
        ' ██╔══██╗██╔════╝██║   ██║      ██╔══██╗██╔══██╗██╔════╝██║ ██╔╝'
        ' ██║  ██║█████╗  ██║   ██║█████╗██████╔╝███████║██║     █████╔╝ '
        ' ██║  ██║██╔══╝  ╚██╗ ██╔╝╚════╝██╔═══╝ ██╔══██║██║     ██╔═██╗ '
        ' ██████╔╝███████╗ ╚████╔╝       ██║     ██║  ██║╚██████╗██║  ██╗'
        ' ╚═════╝ ╚══════╝  ╚═══╝        ╚═╝     ╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝'
        "                   installing dev-pack on Linux...                  "
    )
    printf "\n"
    for line in "${lines[@]}"; do
        printf "  %b%s%b\n" "${SHAZAMP_GRADIENT[$((i % g_len))]}" "$line" "$RESET"
        i=$((i+1))
    done
    printf "\n"
}

# Run a command: show live output, print OK/FAIL/TIMEOUT, never abort on failure
_dp_run() {
    local label="$1"
    local cmd="$2"

    printf "\n%b%s%b %b▶ %s%b\n" \
        "$accent_color" "$TREE_MID" "$RESET" \
        "$LIGHT_ORANGE" "$label" "$RESET"

    local rc=0
    if command -v timeout >/dev/null 2>&1; then
        timeout 300 bash -c "$cmd" || rc=$?
    else
        bash -c "$cmd" || rc=$?
    fi

    if [[ $rc -eq 0 ]]; then
        printf "%b%s%b %b[ OK ]%b  %b%s%b\n" \
            "$accent_color" "$TREE_MID" "$RESET" \
            "$LIGHT_GREEN" "$RESET" \
            "$LIGHT_ORANGE" "$label" "$RESET"
    elif [[ $rc -eq 124 ]]; then
        printf "%b%s%b %b[TIMEOUT]%b  %b%s%b\n" \
            "$accent_color" "$TREE_MID" "$RESET" \
            "$YELLOW" "$RESET" \
            "$LIGHT_ORANGE" "$label" "$RESET"
    else
        printf "%b%s%b %b[FAIL rc=%d]%b  %b%s%b\n" \
            "$accent_color" "$TREE_MID" "$RESET" \
            "$RED" "$rc" "$RESET" \
            "$LIGHT_ORANGE" "$label" "$RESET"
    fi

    return 0
}

# apt install wrapper
_apt() {
    local pkg="$1" desc="$2" apt_name="${3:-$1}"
    _dp_run "${pkg}  (${desc})" \
        "DEBIAN_FRONTEND=noninteractive sudo apt-get install -y $apt_name"
}

_devpack_packages_linux() {

    # ── 1. Package Manager Bootstrap ─────────────────────────────────────
    _dp_section "1. Package Manager Bootstrap"
    _dp_run "apt update" \
        "sudo apt-get update -y"
    _dp_run "apt upgrade" \
        "DEBIAN_FRONTEND=noninteractive sudo apt-get upgrade -y"
    _dp_run "apt base deps" \
        "DEBIAN_FRONTEND=noninteractive sudo apt-get install -y \
            curl wget git gnupg ca-certificates \
            software-properties-common apt-transport-https \
            build-essential pkg-config unzip"

    # ── 2. Go ─────────────────────────────────────────────────────────────
    _dp_section "2. Go"
    _dp_run "golang" \
        'GO_VER=$(curl -s "https://go.dev/VERSION?m=text" | head -1) \
        && curl -fsSL "https://dl.google.com/go/${GO_VER}.linux-amd64.tar.gz" -o /tmp/go.tar.gz \
        && sudo rm -rf /usr/local/go \
        && sudo tar -C /usr/local -xzf /tmp/go.tar.gz \
        && rm -f /tmp/go.tar.gz \
        && grep -q "/usr/local/go/bin" ~/.zprofile || echo "export PATH=\$PATH:/usr/local/go/bin" >> ~/.zprofile \
        && export PATH=$PATH:/usr/local/go/bin'

    # ── 3. Python ─────────────────────────────────────────────────────────
    _dp_section "3. Python"
    _apt "python3-pip"  "pip3"
    _apt "python3-venv" "venv support"
    _dp_run "uv" \
        "curl -LsSf https://astral.sh/uv/install.sh | sh"
    _dp_run "pipx" \
        "pip3 install --user pipx || pip3 install pipx"
    _dp_run "six" \
        "pip3 install six"
    _dp_run "yt-dlp" \
        "pip3 install yt-dlp"

    # ── 4. Node ───────────────────────────────────────────────────────────
    _dp_section "4. Node"
    _dp_run "node via nvm" \
        'curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash \
        && export NVM_DIR="$HOME/.nvm" \
        && [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" \
        && nvm install --lts'
    _dp_run "pnpm" \
        "npm install -g pnpm"

    # ── 5. Rust ───────────────────────────────────────────────────────────
    _dp_section "5. Rust"
    _dp_run "rustup" \
        'curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
        && source "$HOME/.cargo/env"'

    # ── 7. Dev / Build Tools ──────────────────────────────────────────────
    _dp_section "7. Dev / Build Tools"
    _apt "cmake"          "C/C++ build system"
    _apt "clang-format"   "C/C++ code formatter"
    _apt "cppcheck"       "static analysis for C/C++"
    _apt "binutils"       "GNU binary tools"
    _apt "pkg-config"     "helps compilers find libraries"
    _apt "php"            "PHP runtime"         "php"
    _apt "php-cli"        "PHP CLI"

    # ── 8. CLI Favourites ─────────────────────────────────────────────────
    _dp_section "8. CLI Favourites"
    _apt "wget"           "HTTP downloader"
    _apt "curl"           "HTTP client"
    _apt "git"            "version control"
    _apt "telnet"         "telnet client"
    _apt "cmatrix"        "matrix effect"
    _apt "tree"           "nice directory listing"
    _apt "ncdu"           "disk space explorer"
    _apt "mtr"            "traceroute + ping"       "mtr-tiny"
    _apt "imagemagick"    "image converter"
    _apt "lolcat"         "rainbow colors"
    _apt "jq"             "JSON processor for CLI"
    _apt "gnupg"          "GPG encryption & signing" "gnupg2"
    _apt "testdisk"       "recover lost partitions"
    _apt "tmux"           "split terminals, persistent sessions"
    _apt "micro"          "modern terminal editor"
    _apt "htop"           "interactive process viewer"
    _apt "iotop"          "disk I/O monitor"
    _apt "net-tools"      "ifconfig, netstat etc"
    _apt "dnsutils"       "dig, nslookup"
    _apt "rsync"          "file sync"
    _apt "zip"            "zip/unzip"              "zip unzip"

    # ── 9. fzf stack ──────────────────────────────────────────────────────
    _dp_section "9. fzf stack"
    _dp_run "fzf" \
        "git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf && ~/.fzf/install --all"
    _apt "bat"            "syntax-highlighted cat"
    _apt "ripgrep"        "fast grep"
    _dp_run "zoxide" \
        "curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh"

    # ── 10. Media / Audio ─────────────────────────────────────────────────
    _dp_section "10. Media / Audio"
    _apt "ffmpeg"         "video/audio converter"
    _apt "sox"            "audio file converter"

    # ── 11. GitHub CLI ────────────────────────────────────────────────────
    _dp_section "11. GitHub CLI"
    _dp_run "gh CLI" \
        '(type -p wget >/dev/null || sudo apt-get install wget -y) \
        && sudo mkdir -p -m 755 /etc/apt/keyrings \
        && wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
            | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null \
        && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
        && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
            | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null \
        && sudo apt-get update \
        && sudo apt-get install gh -y'
    _dp_run "git global .gitignore" \
        "git config --global core.excludesFile ~/.gitignore_global"

    # ── 12. Security / Pentesting ─────────────────────────────────────────
    _dp_section "12. Security / Pentesting"
    _apt "nmap"           "network port scanner"
    _apt "nikto"          "web server vulnerability scanner"
    _apt "sqlmap"         "automatic SQL injection tool"
    _apt "chkrootkit"     "rootkit scanner"
    _apt "rkhunter"       "rootkit hunter"
    _apt "lynis"          "security auditing tool"
    _apt "wireshark"      "network packet analyser"   "wireshark-common"
    _apt "tcpdump"        "CLI packet capture"
    _apt "netcat"         "netcat"                    "netcat-openbsd"
    _dp_run "trufflehog" \
        "curl -sSfL https://raw.githubusercontent.com/trufflesecurity/trufflehog/main/scripts/install.sh | sh -s -- -b /usr/local/bin"
    _dp_run "feroxbuster" \
        "curl -sL https://raw.githubusercontent.com/epi052/feroxbuster/main/install-nix.sh | bash -s /usr/local/bin"
    _dp_run "nuclei" \
        "export PATH=\$PATH:/usr/local/go/bin && go install -v github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest"
    _dp_run "httpx" \
        "export PATH=\$PATH:/usr/local/go/bin && go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest"
    _dp_run "subfinder" \
        "export PATH=\$PATH:/usr/local/go/bin && go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest"
    _dp_run "gobuster" \
        "export PATH=\$PATH:/usr/local/go/bin && go install github.com/OJ/gobuster/v3@latest"
    _dp_run "ffuf" \
        "export PATH=\$PATH:/usr/local/go/bin && go install github.com/ffuf/ffuf/v2@latest"
    _dp_run "amass" \
        "export PATH=\$PATH:/usr/local/go/bin && go install -v github.com/owasp-amass/amass/v4/...@master"

    # ── 14. Docker ────────────────────────────────────────────────────────
    _dp_section "14. Docker"
    _dp_run "docker" \
        'curl -fsSL https://get.docker.com | sh \
        && sudo usermod -aG docker $USER'
}

function devpack() {
    _dp_init_theme
    _dp_banner
    printf "%bUbuntu/Debian Linux%b detected — %bstarting install..%b\n\n" \
        "$LIGHT_ORANGE" "$RESET" "$DIM_PINK" "$RESET"

    export DEBIAN_FRONTEND=noninteractive

    _devpack_packages_linux

    printf "\n%b%s%b\n" "$accent_color" \
        "└──────────────────────────────────────────────" "$RESET"
    printf "  %b(^_^)/%b  %bdev-pack installed!%b\n\n" \
        "$LIGHT_GREEN" "$RESET" "$LIGHT_ORANGE" "$RESET"
    printf "  %bNOTE:%b Log out and back in for docker group, nvm, cargo, go to take effect.\n\n" \
        "$YELLOW" "$RESET"
}

