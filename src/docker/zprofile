alias docwipe='printf "\nDocker stop & full wipe..\n\n"; docker ps; printf "\n"; docstop; docremove; echo "y" | docker system prune -a; printf "\nDocker Pruned. Done!\n\n"'
alias docbomb='clear; printf "\n💀 Docker Atomic Bomb: wipe everything then rebuild..\n\n"; docwipe; sleep 1; docbuild; sleep 1; docupd; printf "\nAll DONE :)\n"'

# ── dex — interactive container picker ───────────────────────────────────
function dex() {
    local C1=$'\033[38;5;177m'
    local C2=$'\033[38;5;213m'
    local C3=$'\033[38;5;208m'
    local RS=$'\033[0m'
    local DIM=$'\033[2m'

    printf "\n"
    printf "  ${C1} ██████╗ ${C2}███████╗${C3}██╗  ██╗${RS}\n"
    printf "  ${C1}██╔══██╗${C2}██╔════╝${C3}╚██╗██╔╝${RS}\n"
    printf "  ${C1}██║  ██║${C2}█████╗  ${C3} ╚███╔╝ ${RS}\n"
    printf "  ${C1}██║  ██║${C2}██╔══╝  ${C3} ██╔██╗ ${RS}\n"
    printf "  ${C1}██████╔╝${C2}███████╗${C3}██╔╝ ██╗${RS}\n"
    printf "  ${C1}╚═════╝ ${C2}╚══════╝${C3}╚═╝  ╚═╝${RS}\n"
    printf "  ${DIM}${C2}exec into any container${RS}\n"
    printf "\n"

    local selected
    selected=$(
        {
            docker ps --format '{{.Names}}\t{{.Status}}\t{{.Image}}' 2>/dev/null | \
                awk -F'\t' '{printf "%-30s  \033[38;5;82m[running]\033[0m  %-20s  \033[38;5;214m%s\033[0m\n", $1, $2, $3}'
            docker ps -a --filter "status=exited" --filter "status=created" \
                --format '{{.Names}}\t{{.Status}}\t{{.Image}}' 2>/dev/null | \
                awk -F'\t' '{printf "%-30s  \033[38;5;240m[stopped]\033[0m  %-20s  \033[38;5;214m%s\033[0m\n", $1, $2, $3}'
        } | fzf \
            --ansi \
            --prompt $'\033[38;5;177m❯ container \033[0m' \
            --pointer '◆' \
            --marker '●' \
            --border rounded \
            --header $'\033[38;5;213m  ↑↓ select   enter exec   esc cancel\033[0m' \
            --header-first \
            --color 'bg:#1a1a2e,bg+:#2a2a4e,border:#5f5f87,hl:#87d7ff,hl+:#87d7ff,prompt:#d787ff,pointer:#d787ff'
    )

    [ -z "$selected" ] && return 0

    local container
    container=$(echo "$selected" | awk '{print $1}')

    if echo "$selected" | grep -q '\[stopped\]'; then
        printf "${C1}│  ${C2}%s${RS} is stopped. Start it? ${DIM}[y/N]${RS} " "$container"
        read -r answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            docker start "$container"
            sleep 1
        else
            printf "${C3}│  Aborted.${RS}\n\n"
            return 0
        fi
    fi

    printf "\n${C1}│  \033[38;5;82m[ exec ]${RS}  ${C3}%s${RS}\n\n" "$container"
    docker exec -it "$container" bash 2>/dev/null || docker exec -it "$container" sh
}


##########################################################################################
## fz — fuzzy file finder with preview
##
## Usage:
##   fz                    search files in current dir
##   fz <path>             search files in <path>
##   fz <path> <query>     pre-filter filenames by <query>
##   fz -c                 search file CONTENTS in current dir
##   fz -c <path>          search file contents in <path>
##   fz -c <path> <query>  search contents, pre-filter by <query>
##
## Keybindings: ctrl-/ toggle preview
## Dependencies: fzf, bat, ripgrep
##########################################################################################
fz() {
    local content_mode=false
    local dir="."
    local query=""
    local dir_set=false

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -c) content_mode=true ;;
            *)
                if ! $dir_set; then
                    dir="$1"
                    dir_set=true
                else
                    query="$1"
                fi
                ;;
        esac
        shift
    done

    if $content_mode; then
        rg --line-number --no-heading --color=never "$dir" 2>/dev/null \
            | fzf \
                --query "$query" \
                --ansi \
                --delimiter ':' \
                --preview 'bat --color=always --highlight-line {2} --line-range {2}: {1}' \
                --preview-window=right:60%:wrap \
                --bind 'ctrl-/:toggle-preview'
    else
        find "$dir" -type f | fzf \
            --query "$query" \
            --preview 'bat --color=always --line-range=:200 {}' \
            --preview-window=right:60%:wrap \
            --bind 'ctrl-/:toggle-preview'
    fi
}

##########################################################################################
## kk — interactive process killer
##
## Usage: kk <name>
##########################################################################################
kk() {
    local name="${1:?Usage: kk <process name>}"
    ps aux | grep -i "$name" | grep -v grep | fzf | awk '{print $2}' | xargs -I{} kill {}
}

##########################################################################################
## clrhis — clear last N lines from zsh history
##
## Usage:
##   clrhis        wipe entire history
##   clrhis 10     remove last 10 entries
##########################################################################################
clrhis() {
    local n=${1:-9999999999}
    local total
    total=$(wc -l < ~/.zsh_history | awk '{print $1}')
    local keep=$(( total - n ))
    [[ "$keep" -lt 0 ]] && keep=0
    local removed=$(( total - keep ))

    if [[ "$keep" -eq 0 ]]; then
        printf "" > ~/.zsh_history
    else
        head -n "$keep" ~/.zsh_history > ~/.zsh_history.new \
            && mv ~/.zsh_history.new ~/.zsh_history
    fi

    history -c 2>/dev/null || true
    fc -R ~/.zsh_history 2>/dev/null || true

    local -a quotes
    quotes=(
        "what commands? i saw nothing."
        "the evidence has been... handled."
        "your secrets are safe. probably."
        "sudo rm -rf /regrets"
        "history? never heard of her."
        "shredding your crimes since 2024."
        "the NSA is mildly disappointed."
        "no logs, no crime. that's the law."
        "git blame can't save you now."
        "404: history not found."
        "what happens in terminal, stays in terminal."
        "plausible deniability: achieved."
        "CIA wishes they had this tool."
        "history.exe has stopped working."
        "clean slate. dirty mind."
        "this never happened. wink."
        "witnesses: eliminated."
        "men in black would approve."
        "whoami? nobody. that's who."
        "classified. burn after reading."
        "like tears in rain... gone."
        "zsh: i have amnesia again."
        "edward snowden nods approvingly."
        "the matrix has been reset."
        "sudo forget --everything --now"
        "no ragrets. not even one letter."
        "what were we talking about?"
        "alibis secured. you may proceed."
        "redacted. redacted. redacted."
        "commit -m 'nothing to see here'"
        "history? i think you mean: mythology."
    )

    local quote="${quotes[$(( RANDOM % ${#quotes[@]} ))]}"

    local -a frames
    frames[1]="  __|__        (@)\n | ___ |          \n ||   ||          \n ||   ||          \n |_____|          "
    frames[2]="  __|__     (@)   \n | ___ |       \n ||   ||       \n ||   ||       \n |_____|       "
    frames[3]="  __|__  (@)  \n | ___ |     \n ||   ||     \n ||   ||     \n |_____|     "
    frames[4]="  __|__\n |(@)__|\n ||   ||\n ||   ||\n |_____|"
    frames[5]="  __|__\n | ___ |\n ||(o)||\n ||   ||\n |_____|"
    frames[6]="  __|__\n | ___ |\n ||   ||\n ||(o)||\n |_____|"
    frames[7]="  __|__\n | ___ |\n ||(o)||\n ||~~~||\n |_____|"
    frames[8]="  __|__\n | ___ |\n ||~~~||\n ||~~~||\n |_____|"

    for i in 1 2 3 4 5 6 7 8; do
        printf "\033[H\033[2J"
        printf "\n  shredding %d lines...\n" "$removed"
        printf "\n  \"%s\"\n\n" "$quote"
        printf "${frames[$i]}\n"
        sleep 0.13
    done

    for b in 1 2 3; do
        printf "\033[H\033[2J"
        printf "\n  shredding %d lines...\n\n  \"%s\"\n\n  __|__\n | ___ |\n ||~o~||\n ||~~~||\n |_____|\n" "$removed" "$quote"
        sleep 0.07
        printf "\033[H\033[2J"
        printf "\n  shredding %d lines...\n\n  \"%s\"\n\n  __|__\n | ___ |\n ||~~~||\n ||~o~||\n |_____|\n" "$removed" "$quote"
        sleep 0.07
    done

    printf "\033[H\033[2J"
    printf "\n  __|__\n | ___ |\n ||~~~||\n ||~~~||\n |_____|\n\n  (^_^)/  %d lines shredded\n\n  \"%s\"\n\n" "$removed" "$quote"
}

