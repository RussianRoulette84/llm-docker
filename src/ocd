}

# _write_secret_handoff — when `-a` opens a new iTerm/Terminal window,
# that fresh shell does NOT inherit our env, so run-local.sh's
# "BUILDER_API_PASSWORD already loaded" sentinel misses and env-gorilla
# runs again (= extra Touch ID). Dump our forwarding-eligible env to a
# short-lived file under /tmp/s3c-gorilla/ (mode 0600, owner-only, same
# dir as the chip-blobs). The spawned window sources it and immediately
# deletes it. ~1 second on disk. Echoes path, or empty if nothing written.
_write_secret_handoff() {
    local dir="/tmp/s3c-gorilla"
    mkdir -p "$dir" 2>/dev/null || return 0
    chmod 700 "$dir" 2>/dev/null
    local f
    f=$(mktemp "$dir/handoff-XXXXXXXX" 2>/dev/null) || return 0
    chmod 600 "$f"
    local _block='^(PATH|HOME|TMPDIR|PWD|OLDPWD|SHELL|USER|LOGNAME|HOSTNAME|SHLVL|LD_.+|DYLD_.+|LLM_DOCKER_ENV_GORILLA)$'
    local n=0 k v
    while IFS='=' read -r k v; do
        [ -z "$k" ] && continue
        [[ "$k" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
        [[ "$k" =~ $_block ]] && continue
        printf 'export %s=%q\n' "$k" "$v" >>"$f"
        n=$((n+1))
    done < <(env)
    if [ "$n" -eq 0 ]; then
        rm -f "$f"
        return 0
    fi
    echo "$f"
}

# _maybe_start_api — spawn the builder-api server in a separate window if
# --api was passed AND one isn't already listening on the configured port.
# macOS: osascript opens a new Terminal window. Otherwise: background + log.
_maybe_start_api() {
    [ "$START_API" = true ] || return 0

    local project_dir="$1"
    local project_name
    project_name="$(basename "$project_dir")"
    local port
    # Port precedence: host's ~/.llm-docker/builder-api.toml under
    # [project.<name>].port → llm-docker.conf → default 6666. Per-project
    # .builder-api.toml files are NO LONGER read.
    local host_toml="${HOME}/.llm-docker/builder-api.toml"
    if [ -f "$host_toml" ]; then
        port=$(awk -v p="project.$project_name" '
            $0 ~ "^\\[" p "\\]" { in_block=1; next }
            in_block && /^\[/ { in_block=0 }
            in_block && /^[[:space:]]*port[[:space:]]*=/ {
                gsub(/^[[:space:]]*port[[:space:]]*=[[:space:]]*/, "")
                gsub(/[^0-9].*$/, "")
                print; exit
            }
        ' "$host_toml")
    fi
    if [ -z "${port:-}" ]; then
        port="$(_read_env_var BUILDER_API_PORT "$SCRIPT_DIR/llm-docker.conf" 2>/dev/null)"
    fi
    port="${port:-6666}"

    # The applescript's SESSION_TITLE reuse path handles dedup — if a
    # tagged iTerm pane already exists it kills the old daemon and
    # relaunches in the same pane. No TCP probe needed here.

    local launcher="$SCRIPT_DIR/builder-api/run-local.sh"
    if [ ! -f "$launcher" ]; then
        echo "[ocd] warning: $launcher not found; skipping --api spawn" >&2
        return 0
    fi

    if [[ "$OSTYPE" == "darwin"* ]]; then
        local log="/tmp/builder-api-$$.log"

        if [ "$START_API_BG" = true ]; then
            nohup bash "$launcher" "$project_dir" >"$log" 2>&1 &
            disown $! 2>/dev/null || true
            echo "[ocd] builder-api in background — PID $! · log: $log"
            return 0
        fi

        # Hand our already-unwrapped secrets to the new Terminal window
        # via a short-lived file, so run-local.sh's sentinel skips its
        # own env-gorilla call (= no extra Touch ID).
        local handoff
        handoff="$(_write_secret_handoff)"

        # 1a) Already inside iTerm? Split the current window left/right.
        if [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
            if osascript "$SCRIPT_DIR/builder-api/builder_api.applescript" "$launcher" "$project_dir" split "$port" "$handoff" >/dev/null 2>&1; then
                echo "[ocd] builder-api split into right pane (port $port)"
                return 0
            fi
        fi

        # 1b) Not in iTerm, or split denied: positioned new window.
        if osascript "$SCRIPT_DIR/builder-api/builder_api.applescript" "$launcher" "$project_dir" new-window "$port" "$handoff" >/dev/null 2>&1; then
            echo "[ocd] builder-api spawned in positioned iTerm window (port $port)"
            return 0
        fi

        # 2) AppleScript denied — `open` a .command file via LaunchServices.
        local cmd_file
        cmd_file=$(mktemp -t builder-api.XXXXXX).command
        cat >"$cmd_file" <<EOF
#!/bin/bash
cd "$project_dir"
exec bash "$launcher" "$project_dir" "$handoff"
EOF
        chmod +x "$cmd_file"
        if [ -d "/Applications/iTerm.app" ] && open -a iTerm "$cmd_file" 2>/dev/null; then
            echo "[ocd] WARNING: AppleScript blocked — opened iTerm without positioning." >&2
            return 0
        fi
        if open -a Terminal "$cmd_file" 2>/dev/null; then
            echo "[ocd] WARNING: Opened Terminal.app instead of iTerm." >&2
            return 0
        fi

        # 3) Background fallback.
        echo "[ocd] WARNING: No terminal app available. Backgrounding." >&2
        nohup bash "$launcher" "$project_dir" >"$log" 2>&1 &
        disown $! 2>/dev/null || true
        echo "[ocd] builder-api in background — PID $! · log: $log"
    else
        local log="/tmp/builder-api-$$.log"
        nohup bash "$launcher" "$project_dir" > "$log" 2>&1 &
        echo "[ocd] builder-api started in background (pid $!, log: $log)"
    fi
}

# --api: start the builder-api BEFORE fan-out so we spawn it exactly once
# (multi-llm-docker.applescript's children don't inherit START_API).
# When -a/--api wasn't given, fall back to BUILDER_API_AUTOSTART from
# llm-docker.conf so users can opt in once instead of typing -a every launch.
if [ "$START_API_EXPLICIT" = false ]; then
    _autostart="$(_read_env_var BUILDER_API_AUTOSTART "$SCRIPT_DIR/llm-docker.conf" 2>/dev/null)"
    case "$(printf '%s' "$_autostart" | tr '[:upper:]' '[:lower:]')" in
        true|yes|on|1) START_API=true ;;
    esac
    unset _autostart
fi
_maybe_start_api "$CURRENT_DIR"

# If WINDOW_COUNT > 1 and we're on macOS with iTerm2, open multiple windows
# If WINDOW_COUNT > 1 and we're on macOS, use multi-llm-docker layout
if [ "$WINDOW_COUNT" -gt 1 ] && [[ "$OSTYPE" == "darwin"* ]]; then
    SLOT_MODE="new"
    [ "$CONTINUE_SESSION" = true ] && SLOT_MODE="restore"
    _log OCD "Opening $WINDOW_COUNT terminal windows ($SLOT_MODE mode)..."
    _OSA_ERR=$(osascript "$SCRIPT_DIR/multi-llm-docker.applescript" "$SCRIPT_DIR/ocd" "$WINDOW_COUNT" "$CURRENT_DIR" "$SLOT_MODE" 2>&1)
    _OSA_RC=$?
    if [ "$_OSA_RC" -ne 0 ]; then
        if printf '%s' "$_OSA_ERR" | grep -qE -- '-1743|Not authori[sz]ed'; then
            _log OCD ERROR "macOS blocked AppleScript from controlling iTerm."
            _log OCD "Resetting the permission now so macOS will re-prompt..."
            tccutil reset AppleEvents com.googlecode.iterm2 2>/dev/null || true
            _log OCD "Now rerun: ${C2}ocd $WINDOW_COUNT${RST}"
            _log OCD "macOS will prompt 'iTerm wants to control iTerm' — click Allow."
            _log OCD "Permanent fix: System Settings → Privacy & Security → Automation → iTerm → check iTerm."
        else
            _log OCD ERROR "multi-window layout failed:"
            printf '%s\n' "$_OSA_ERR" | sed 's/^/    /'
        fi
        exit 1
    fi
    exit 0
fi

# Single window - run directly
run_opencode_container "$CURRENT_DIR" "$@"
