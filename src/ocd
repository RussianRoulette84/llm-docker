#!/bin/bash

set -e

# --- env-gorilla integration: inject KeePassXC-backed secrets before launch.
# Loads the `llm-docker` profile (cage-wide keys) AND, if the CWD's basename
# is a different name, that project's profile too — both merged into a single
# chip-blob by env-gorilla v0.12+ so one Touch ID covers everything. A missing
# project profile in kdbx is a non-fatal warning, not an error.
_self_dir="$( cd "$( dirname "$( realpath "${BASH_SOURCE[0]}" )" )" && pwd )"
if [ -z "${LLM_DOCKER_ENV_GORILLA:-}" ] \
   && command -v env-gorilla >/dev/null 2>&1 \
   && { [ "${USER:-}" = "yaro" ] || [ ! -f "$_self_dir/.env" ]; }; then
    _proj_dir=""
    for _a in "$@"; do
        case "$_a" in
            -*) ;;
            *) [ -d "$_a" ] && { _proj_dir="$(realpath "$_a")"; break; } ;;
        esac
    done
    [ -z "$_proj_dir" ] && _proj_dir="$(pwd)"
    _proj_name="$(basename "$_proj_dir")"
    unset _proj_dir _a

    if [ -n "$_proj_name" ] && [ "$_proj_name" != "llm-docker" ]; then
        _profiles="llm-docker,$_proj_name"
    else
        _profiles="llm-docker"
    fi
    export LLM_DOCKER_ENV_GORILLA=1
    exec env-gorilla "$_profiles" -- "$0" "$@"
fi
unset _self_dir _proj_name _profiles

SCRIPT_DIR="$( cd "$( dirname "$( realpath "${BASH_SOURCE[0]}" )" )" && pwd )"

source "$SCRIPT_DIR/setup.sh"

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    _log OCD WARNING "Docker is not running — starting Docker Desktop..."

    # Start Docker Desktop on macOS
    if [[ "$OSTYPE" == "darwin"* ]]; then
        open -a Docker
    else
        _log OCD ERROR "Please start Docker manually on your system"
        exit 1
    fi

    _log OCD "Waiting for Docker to start (this may take a minute)..."
    max_wait=60
    waited=0
    until docker info > /dev/null 2>&1; do
        if [ $waited -ge $max_wait ]; then
            _log OCD ERROR "Docker did not start within $max_wait seconds"
            exit 1
        fi
        echo -n "."
        sleep 2
        waited=$((waited + 2))
    done
    _log OCD "Docker is ready!"
fi

# Quick pre-scan for the two rebuild flags:
#   --build         smart rebuild: re-runs install scripts inside the existing
#                   image and `docker commit`s, skipping already-installed
#                   tools (Go binaries, cargo crates, npm globals, etc.).
#                   Layer-on-top — fast but accumulates cruft over time.
#   --rebuild-force full rebuild from the Dockerfile: docker rmi + docker build.
#                   Slow but produces a clean image.
_user_requested_build=false
_user_requested_force_rebuild=false
for _arg in "$@"; do
    case "$_arg" in
        --rebuild-force)
            _user_requested_force_rebuild=true
            _log OCD "Force rebuild (--rebuild-force) — removing llm-docker-opencode:latest + llm-docker:latest..."
            docker rmi llm-docker-opencode:latest llm-docker:latest 2>/dev/null || true
            ;;
        --build)
            _user_requested_build=true
            ;;
    esac
done
unset _arg

# Pre-scan: if the user passed -t/-tt/-tc but the matching INSTALL_TMUX_* is
# still false, the tmux binary / helper won't be in the image. Offer to flip
# the flag and rebuild.
_tmux_flip_kvs=""
_tmux_flip_labels=""
_register_tmux_flip() {
    local flag="$1" label="$2"
    local cur
    cur="$(_read_env_var "$flag" "$SCRIPT_DIR/llm-docker.conf" 2>/dev/null)"
    [ "$cur" = "true" ] && return 0
    case " $_tmux_flip_kvs " in *" ${flag}=true "*) return 0 ;; esac
    _tmux_flip_kvs+="${flag}=true "
    [ -n "$_tmux_flip_labels" ] && _tmux_flip_labels+=", "
    _tmux_flip_labels+="$label"
}
for _arg in "$@"; do
    case "$_arg" in
        -t|--tmux)          _register_tmux_flip INSTALL_TMUX_VANILLA "-t (vanilla tmux)" ;;
        -tt|--tmux-team)    _register_tmux_flip INSTALL_TMUX_TEAM    "-tt (tmux team layout)" ;;
        -tc|--tmux-codeman) _register_tmux_flip INSTALL_TMUX_CODEMAN "-tc (Ark0N/Codeman)" ;;
        --) break ;;
    esac
done
unset _arg

if [ -n "$_tmux_flip_kvs" ]; then
    if [ "$_user_requested_build" = true ] || [ "$_user_requested_force_rebuild" = true ]; then
        _log OCD "Enabling: ${_tmux_flip_labels}"
    else
        _log OCD "Tmux flag(s) requested but not baked into the image: ${_tmux_flip_labels}"
        if [ -t 0 ]; then
            printf "  [ocd] Enable and rebuild image now (smart)? [Y/n] "
            read -r _ans
        else
            _ans="y"
        fi
        case "${_ans:-y}" in
            n|N|no|No|NO)
                _log OCD ERROR "Aborted. Re-run with the flag after enabling INSTALL_TMUX_* in llm-docker.conf."
                exit 1
                ;;
        esac
        _user_requested_build=true
    fi
    for _kv in $_tmux_flip_kvs; do
        _k="${_kv%%=*}"; _v="${_kv#*=}"
        if grep -q "^${_k}=" "$SCRIPT_DIR/llm-docker.conf"; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' "s|^${_k}=.*|${_k}=${_v}|" "$SCRIPT_DIR/llm-docker.conf"
            else
                sed -i "s|^${_k}=.*|${_k}=${_v}|" "$SCRIPT_DIR/llm-docker.conf"
            fi
        else
            printf "\n%s=%s\n" "$_k" "$_v" >> "$SCRIPT_DIR/llm-docker.conf"
        fi
    done
    unset _ans _kv _k _v
fi
unset _tmux_flip_kvs _tmux_flip_labels

# Auto-setup on first run (dirs, .env, image).
# Build the opencode-only image (llm-docker-opencode:latest). If install.sh
# has already produced the combined llm-docker:latest, that's reused —
# otherwise we skip the claude-code install entirely.
run_setup opencode

# Smart rebuild (--build): re-run install scripts inside the existing image
# and commit. No-op when --rebuild-force already triggered a full build via
# run_setup, since the image is now fresh.
if [ "$_user_requested_build" = true ] && [ "$_user_requested_force_rebuild" != true ]; then
    setup_image_incremental opencode || _log OCD ERROR "Smart rebuild reported errors — see logs/llm-docker.log"
fi
unset _user_requested_build _user_requested_force_rebuild

# DOCKER_DIR = container-side parent for every mount (default /root).
# WORKSPACE_DIR = optional host dir persistently mirrored at DOCKER_DIR/basename.
WORKSPACE_DIR=""
DOCKER_DIR=""
if [ -f "$SCRIPT_DIR/llm-docker.conf" ]; then
    WS_ENV="$(_read_env_var WORKSPACE_DIR "$SCRIPT_DIR/llm-docker.conf")"
    [ -n "$WS_ENV" ] && WORKSPACE_DIR="${WS_ENV/#\~/$HOME}"
    DD_ENV="$(_read_env_var DOCKER_DIR "$SCRIPT_DIR/llm-docker.conf")"
    [ -n "$DD_ENV" ] && DOCKER_DIR="$DD_ENV"
fi
: "${DOCKER_DIR:=/root}"

WORKSPACE_MOUNT_ACTIVE=false
DOCKER_WORKSPACE_TARGET=""
if [ -n "$WORKSPACE_DIR" ]; then
    DOCKER_WORKSPACE_TARGET="$DOCKER_DIR/$(basename "$WORKSPACE_DIR")"
    if ! _validate_workspace_paths "$WORKSPACE_DIR" "$DOCKER_WORKSPACE_TARGET"; then
        _log OCD ERROR "Invalid WORKSPACE_DIR — edit $SCRIPT_DIR/llm-docker.conf"
        exit 1
    fi
    WORKSPACE_MOUNT_ACTIVE=true
fi
export WORKSPACE_DIR DOCKER_DIR WORKSPACE_MOUNT_ACTIVE DOCKER_WORKSPACE_TARGET

# Capture current directory before changing to script directory
CURRENT_DIR=$(pwd)
WINDOW_COUNT=1
WINDOW_DELAY=0.5
CONTINUE_SESSION=false
RESUME_SESSION=""
SLOT=""
START_API=false           # --api / -a toggle; see _maybe_start_api below
START_API_BG=false        # -ab / --api-bg: skip the window, background only
START_API_EXPLICIT=false  # set by -a/-ab/--api so a missing flag falls back to conf's BUILDER_API_AUTOSTART
CLEAN_CONTAINERS=false   # --clean: stop/remove leftover llm-docker containers
USE_TMUX=false     # -t / --tmux: wrap opencode launch inside a tmux session
TMUX_TEAM=false    # -tt / --tmux-team: multi-pane tmux layout inside one container
TMUX_TEAM_SIZE=0   # 0=default (1+3), 2=side-by-side, 3=1+2 stacked, 4=2x2 grid
TMUX_CODEMAN=false # -tc / --tmux-codeman: launch Ark0N/Codeman web UI (port 3000)

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--delay)
            WINDOW_DELAY="$2"
            shift 2
            ;;
        -c|--continue)
            # -c alone = continue last. -c <UUID> = resume specific session.
            # -c <N> (numeric) = continue + window count (N handled as positional).
            if [[ -n "$2" && "$2" != -* && ! "$2" =~ ^[0-9]+$ ]]; then
                RESUME_SESSION="$2"
                shift 2
            else
                CONTINUE_SESSION=true
                shift
            fi
            ;;
        --slot)
            SLOT="$2"
            shift 2
            ;;
        --)
            # Stop parsing; everything after `--` passes through to opencode.
            shift
            break
            ;;
        --clean)
            CLEAN_CONTAINERS=true
            shift
            ;;
        --build|--rebuild-force)
            # Already handled by the pre-scan above (smart rebuild / docker rmi).
            shift
            ;;
        -tt|--tmux-team)
            TMUX_TEAM=true
            if [[ -n "$2" && "$2" =~ ^[234]$ ]]; then
                TMUX_TEAM_SIZE="$2"
                shift 2
            elif [[ -n "$2" && "$2" =~ ^[0-9]+$ ]]; then
                echo "ocd: -tt supports sizes 2, 3, or 4 (got '$2'). Omit the number for the default 1+3 layout." >&2
                exit 1
            else
                shift
            fi
            ;;
        -tc|--tmux-codeman)
            TMUX_CODEMAN=true
            shift
            ;;
        -t|--tmux)
            USE_TMUX=true
            shift
            ;;
        -a|--api)
            # -a alone = true. -a true/false = explicit. Anything else
            # after the flag is treated as the next arg.
            START_API_EXPLICIT=true
            if [[ -n "$2" && "$2" =~ ^(true|false|yes|no|on|off|1|0)$ ]]; then
                case "$2" in
                    true|yes|on|1) START_API=true ;;
                    *)             START_API=false ;;
                esac
                shift 2
            else
                START_API=true
                shift
            fi
            ;;
        -ab|--api-bg)
            START_API=true
            START_API_BG=true
            START_API_EXPLICIT=true
            shift
            ;;
        -h|--help)
            cat <<'HELP'
ocd — OpenCode wrapper (Dockerized, sandboxed, slot-aware)

USAGE
  ocd [DIRECTORY] [WINDOW_COUNT] [FLAGS...] [-- OPENCODE_ARGS...]

POSITIONAL
  DIRECTORY             Project directory (default: current).
  WINDOW_COUNT          Number of macOS terminal windows to open in the grid
                        layout (default: 1). Combined with -c, each window
                        restores its own slot (auto --slot 1..N).

SESSION / SLOT
  -c, --continue        Continue the most recent session in this directory.
  -c <UUID>             Resume a specific OpenCode session by UUID.
  --slot <N>            Auto-save/restore a tagged session for slot N.
                        `-c --slot N` resumes slot N's last session.
  -d, --delay <sec>     Seconds between opening windows (default: 0.5).

TMUX MODES  (mutually exclusive — pick at most one)
  -t,  --tmux           Wrap opencode in a tmux session inside the container.
                        Detach with Ctrl+b d. If host is already in tmux,
                        you'll be prompted how to handle nesting.

  -tt, --tmux-team [N]  Multi-pane opencode, ONE container, shared FS/sessions.
                        Pink border = active pane, dim borders for the rest.
                          (no N)  1 main + 3 stacked   (4 panes)
                          N=2     side-by-side         (2 panes)
                          N=3     1 main + 2 stacked   (3 panes)
                          N=4     2x2 grid             (4 panes)

  -tc, --tmux-codeman   Launch Ark0N/Codeman — web UI for session management
                        on http://localhost:3000 (port 3000 auto-published on
                        the container). Baked into every image. Works for
                        OpenCode or Claude sessions.
                        https://github.com/Ark0N/Codeman

BUILDER API
  -a, --api [bool]      Spawn the host-side builder-api daemon in a new
                        terminal. `-a` alone = on. `-a false` = off.
                        Default: off. Requires BUILDER_API_PASSWORD in .env.

CONTAINER LIFECYCLE
  --clean               Stop + remove any leftover llm-docker containers
                        before launching (filters on label
                        com.docker.compose.project=llm-docker).
  --build               Smart rebuild — re-runs the install scripts INSIDE the
                        existing image and `docker commit`s the result. Skips
                        already-installed tools (Go binaries, cargo crates, npm
                        globals, ferox/nikto/codeman). Fast; use after flipping
                        an INSTALL_* flag or editing install_devpack.sh /
                        install_cli.sh. Falls back to a full build when no
                        image exists yet.
  --rebuild-force       Full rebuild from the Dockerfile — removes
                        llm-docker-opencode:latest + llm-docker:latest, then
                        rebuilds from scratch. Slow but clean. Use when --build
                        cruft is bothering you, or when you've edited the
                        Dockerfile itself.

PASSTHROUGH
  --                    Everything after `--` is forwarded to opencode verbatim.
                        Note: `-s` is NOT aliased to --slot here — OpenCode's
                        native `-s <uuid>` = --session. Use `--slot N` for our
                        slot system, or `ocd -- -s <uuid>` for opencode's flag.
                        Examples:
                          ocd -c -- --session <uuid>
                          ocd -- --fork --model gpt-4
                          ocd -- -s <uuid>

EXAMPLES
  ocd                                Fresh session in CWD
  ocd -c                             Continue last session
  ocd 4                              4 terminals, fresh sessions
  ocd -c 4                           4 terminals, each restores its slot
  ocd --slot 2 -c                    Resume slot 2
  ocd -tt                            4-pane team (1 + 3 stacked)
  ocd -tt 2                          Side-by-side team
  ocd -tc                            Launch Codeman web UI on :3000
  ocd ./my-project -a                Open my-project + start builder-api

CONFIG (in src/)
  .env                  Secrets: OPENAI_API_KEY, ZAI_API_KEY,
                        BUILDER_API_PASSWORD, LLM_DOCKER_SSH_AUTHORIZED_KEYS
  llm-docker.conf       Everything else: DOCKER_DIR, WORKSPACE_DIR,
                        SANDBOX_ENABLED, INTERNET_ACCESS, INSTALL_* groups,
                        SSH settings

NOTES
  * Sessions are workdir-scoped: `ocd -c` in ~/Projects/foo won't see
    sessions started in ~/Projects/bar.
  * Bind-mounted from host (auto when present):
      ~/.tmux.conf   →  /root/.tmux.conf   (your keybindings)
      ~/.p10k.zsh    →  /root/.p10k.zsh    (prompt, no wizard)
  * `-tr` (recon) is cld-only — it's a Claude Code dashboard.

DOCS
  README.md             Full setup, architecture, security model, SSH,
                        builder-api
HELP
            exit 0
            ;;
        *)
            if [[ "$1" =~ ^[0-9]+$ ]]; then
                WINDOW_COUNT=$1
                shift
            elif [ -d "$1" ]; then
                CURRENT_DIR=$(realpath "$1")
                shift
            else
                break
            fi
            ;;
    esac
done

# --clean: stop + remove any leftover llm-docker containers before launching.
if [ "$CLEAN_CONTAINERS" = true ]; then
    # Label-based so both llm-docker:latest and llm-docker-<tool>:latest match.
    _leftover_ids=$(docker ps -aq --filter "label=com.docker.compose.project=llm-docker" 2>/dev/null)
    if [ -n "$_leftover_ids" ]; then
        _log OCD "Cleaning up $(echo "$_leftover_ids" | wc -l | tr -d ' ') leftover llm-docker container(s)..."
        docker stop $_leftover_ids >/dev/null 2>&1 || true
        docker rm -f $_leftover_ids >/dev/null 2>&1 || true
        _log OCD "Done."
    else
        _log OCD "No leftover llm-docker containers to clean."
    fi
fi

# Function to run a single OpenCode container
run_opencode_container() {
    local WORKDIR="$1"
    shift
    cd "$SCRIPT_DIR"

    _tmux_nested_prompt

    CWD_BASE="$(basename "$WORKDIR")"
    PER_INVOKE_TARGET="$DOCKER_DIR/$CWD_BASE"
    ADD_PER_INVOKE_MOUNT=false

    if [ "$WORKSPACE_MOUNT_ACTIVE" = true ] && [[ "$WORKDIR" == "$WORKSPACE_DIR"* ]]; then
        RELATIVE_PATH="${WORKDIR#$WORKSPACE_DIR}"
        RELATIVE_PATH="${RELATIVE_PATH#/}"
        if [ -z "$RELATIVE_PATH" ]; then
            DOCKER_WORKDIR="$DOCKER_WORKSPACE_TARGET"
        else
            DOCKER_WORKDIR="$DOCKER_WORKSPACE_TARGET/$RELATIVE_PATH"
        fi
    else
        if [ "$WORKSPACE_MOUNT_ACTIVE" = true ] && [ "$PER_INVOKE_TARGET" = "$DOCKER_WORKSPACE_TARGET" ]; then
            _log OCD ERROR "CWD basename '$CWD_BASE' collides with persistent workspace mount at $DOCKER_WORKSPACE_TARGET. Rename the folder or launch from elsewhere."
            exit 1
        fi
        if ! _validate_workspace_paths "$WORKDIR" "$PER_INVOKE_TARGET"; then
            _log OCD ERROR "Launch ocd from inside a specific project folder and try again."
            exit 1
        fi
        ADD_PER_INVOKE_MOUNT=true
        DOCKER_WORKDIR="$PER_INVOKE_TARGET"
    fi

    _log OCD "Starting OpenCode sandbox in $DOCKER_WORKDIR..."

    # Forward terminal environment variables for proper mouse reporting and scrolling
    if command -v stty > /dev/null 2>&1; then
        TERM_SIZE=$(stty size 2>/dev/null || echo "24 80")
        export LINES=$(echo $TERM_SIZE | cut -d' ' -f1)
        export COLUMNS=$(echo $TERM_SIZE | cut -d' ' -f2)
    fi

    export TERM=${TERM:-xterm-256color}

    # Load llm-docker.conf (config) + .env (secrets) into shell env.
    # Order: conf first, .env second — .env wins on conflicts.
    _source_all_config

    # SSH port publish requires bridge networking.
    # Slot N → 8884 + (N - 1). No slot → base port with auto-bump when taken.
    # See cld for the same logic.
    SSH_PORT_MAPPING=""
    SSH_HOST_KEY_MOUNT=""
    if [ "${LLM_DOCKER_SSH_ENABLED:-false}" = "true" ]; then
        _SSH_BASE="${LLM_DOCKER_SSH_HOST_PORT:-8884}"
        _SSH_CONTAINER="${LLM_DOCKER_SSH_PORT:-22}"
        if [ -n "$SLOT" ]; then
            _SSH_HOST_PORT=$(( _SSH_BASE + SLOT - 1 ))
        else
            _SSH_HOST_PORT="$_SSH_BASE"
            _SSH_MAX=$(( _SSH_BASE + 50 ))
            while (timeout 1 bash -c "</dev/tcp/127.0.0.1/$_SSH_HOST_PORT") 2>/dev/null; do
                _SSH_HOST_PORT=$(( _SSH_HOST_PORT + 1 ))
                if [ "$_SSH_HOST_PORT" -gt "$_SSH_MAX" ]; then
                    _log OCD ERROR "No free SSH port in $_SSH_BASE-$_SSH_MAX. Stop some containers or pass --slot N."
                    exit 1
                fi
            done
            if [ "$_SSH_HOST_PORT" != "$_SSH_BASE" ]; then
                _log OCD "SSH port $_SSH_BASE busy — using $_SSH_HOST_PORT (ssh -p $_SSH_HOST_PORT root@localhost)"
            fi
        fi
        SSH_PORT_MAPPING="-p ${_SSH_HOST_PORT}:${_SSH_CONTAINER}"
        SSH_HOST_KEY_MOUNT="-v $HOME/.llm-docker/ssh:/etc/ssh/keys"
    fi

    # Session restore resolution:
    #   -c <UUID>     → RESUME_SESSION (direct)
    #   -c -s N       → read slot file, fall into RESUME_SESSION
    # Whatever ends up in RESUME_SESSION is forwarded as SLOT_RESUME_ID.
    if [ -z "$RESUME_SESSION" ] && [ -n "$SLOT" ] && [ "$CONTINUE_SESSION" = true ]; then
        local SLOT_FILE="$HOME/.llm-docker/opencode/.local/share/opencode/slot_${SLOT}.id"
        [ -f "$SLOT_FILE" ] && RESUME_SESSION="$(cat "$SLOT_FILE")"
    fi
    SLOT_ENV=""
    [ -n "$SLOT" ]           && SLOT_ENV="$SLOT_ENV -e SLOT=$SLOT"
    [ -n "$RESUME_SESSION" ] && SLOT_ENV="$SLOT_ENV -e SLOT_RESUME_ID=$RESUME_SESSION"

    # Fresh session only → entrypoint injects --prompt. Prefer BOOT.md contents, fall back to CLAUDE.md default.
    export OPENCODE_INIT_PROMPT=""
    if [ -z "$RESUME_SESSION" ] && [ "$CONTINUE_SESSION" != true ]; then
        if [ -f "$WORKDIR/BOOT.md" ]; then
            export OPENCODE_INIT_PROMPT="$(cat "$WORKDIR/BOOT.md")"
        elif [ -f "$WORKDIR/CLAUDE.md" ]; then
            export OPENCODE_INIT_PROMPT="Read ./CLAUDE.md in full and follow its BOOT steps before anything else."
        fi
    fi

    # Codeman web UI on port 3000 needs bridge networking to publish with `-p`.
    CODEMAN_PORT_MAPPING=""
    [ "$TMUX_CODEMAN" = true ] && CODEMAN_PORT_MAPPING="-p 3000:3000"

    if [ "${INTERNET_ACCESS:-true}" = "false" ] || [ -n "$SSH_PORT_MAPPING" ] || [ -n "$CODEMAN_PORT_MAPPING" ]; then
        export NETWORK_MODE=bridge
    else
        export NETWORK_MODE=host
    fi

    # Cap/security flags from the same source-of-truth cld uses.
    _compute_cap_flags "${SANDBOX_ENABLED:-true}" "${INTERNET_ACCESS:-true}" "${LLM_DOCKER_SSH_ENABLED:-false}" CAP_DROP CAP_ADD SECURITY_OPT

    # Forward both config files into the container as env. Docker accepts
    # multiple --env-file flags; conf first so .env can still override.
    ENV_FILES=""
    [ -f "$SCRIPT_DIR/llm-docker.conf" ] && ENV_FILES="$ENV_FILES --env-file $SCRIPT_DIR/llm-docker.conf"
    [ -f "$SCRIPT_DIR/.env" ]            && ENV_FILES="$ENV_FILES --env-file $SCRIPT_DIR/.env"

    # Workspace bind: persistent pair if configured, else just the current dir.
    WORKSPACE_MOUNT_ARG=()
    [ "$WORKSPACE_MOUNT_ACTIVE" = true ] && WORKSPACE_MOUNT_ARG+=(-v "$WORKSPACE_DIR:$DOCKER_WORKSPACE_TARGET")
    [ "$ADD_PER_INVOKE_MOUNT" = true ]   && WORKSPACE_MOUNT_ARG+=(-v "$WORKDIR:$PER_INVOKE_TARGET")

    TMUX_CONF_MOUNT_ARG=()
    [ -f "$HOME/.tmux.conf" ] && TMUX_CONF_MOUNT_ARG=(-v "$HOME/.tmux.conf:/root/.tmux.conf:ro")

    P10K_MOUNT_ARG=()
    [ -f "$HOME/.p10k.zsh" ] && P10K_MOUNT_ARG=(-v "$HOME/.p10k.zsh:/root/.p10k.zsh:ro")

    # CAP_* / SECURITY_OPT are unquoted on purpose — they word-split into
    # multiple --cap-add / --cap-drop / --security-opt args.
    local CONTAINER_NAME="llm-docker-opencode-$$"

    _iterm_tag "OpenCode" "$WORKDIR"
    trap '_iterm_untag' EXIT INT TERM HUP

    # Resolve image tag: prefer the opencode-only image, fall back to the
    # combined llm-docker:latest if that's what install.sh produced.
    local IMAGE_TAG
    IMAGE_TAG="$(_llm-docker_image_for_tool opencode)"

    # Forward every env var into the container. Tiny blocklist: only vars
    # that would BREAK the container if a Mac value leaked in (PATH points
    # at /Users/yaro/..., HOME points at a path that doesn't exist, loader
    # hijack via LD_/DYLD_, etc.) plus the env-gorilla re-exec guard.
    local EXTRA_ENV=""
    local _ENV_BLOCK _ename
    _ENV_BLOCK='^(PATH|HOME|TMPDIR|PWD|OLDPWD|SHELL|USER|LOGNAME|HOSTNAME|SHLVL|LD_.+|DYLD_.+|LLM_DOCKER_ENV_GORILLA)$'
    while IFS='=' read -r _ename _; do
        [ -z "$_ename" ] && continue
        [[ "$_ename" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
        [[ "$_ename" =~ $_ENV_BLOCK ]] && continue
        EXTRA_ENV="$EXTRA_ENV -e $_ename"
    done < <(env)

    docker run --rm -it \
        --label com.docker.compose.project=llm-docker \
        --label "llm-docker-project=$CWD_BASE" \
        --hostname llm-docker \
        --name "$CONTAINER_NAME" \
        -w "$DOCKER_WORKDIR" \
        --network "$NETWORK_MODE" \
        $SSH_PORT_MAPPING \
        $CODEMAN_PORT_MAPPING \
        $CAP_DROP \
        $CAP_ADD \
        $SECURITY_OPT \
        "${WORKSPACE_MOUNT_ARG[@]}" \
        "${TMUX_CONF_MOUNT_ARG[@]}" \
        "${P10K_MOUNT_ARG[@]}" \
