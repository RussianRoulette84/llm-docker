{
    "name": "example/php-example",
    "description": "Minimal PHP project wired up to llm-docker (built-in dev server + builder-api jobs + MCP).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "laravel/pint": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "PhpExample\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpExample\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
