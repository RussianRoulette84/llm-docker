# LLM Docker — SECRETS ONLY
#
# This file holds API keys and passwords. It is gitignored — never commit it.
# Non-secret configuration lives in llm-docker.conf alongside this file.
#
# llm-docker.conf is sourced FIRST, then .env, so anything you put here
# overrides llm-docker.conf (useful for per-machine token overrides).

# ============================================
# API KEYS
# ============================================
OPENAI_API_KEY=
ZAI_API_KEY=

# Claude
# use /login with subscription if you have that! Otherwise u will get surprise charges.
# ANTHROPIC_API_KEY=

# ============================================
# SSH authorized_keys (optional)
# ============================================
# Public key(s) that can log in to the container as root when
# LLM_DOCKER_SSH_ENABLED=true. Multiple keys: separate with literal \n.
# install.sh detects ~/.ssh/*.pub on the host and pre-fills this for you.
LLM_DOCKER_SSH_AUTHORIZED_KEYS=ssh-rsa AAAA...ENf username@host

# ============================================
# Builder API password (optional)
# ============================================
# Shared password for the host-side builder-api daemon. Send as
# X-Builder-API-Password on write endpoints. REQUIRED when the daemon
# binds to anything other than 127.0.0.1. See builder-api/README.md.
BUILDER_API_PASSWORD=YOUR_LLM_DOCKER_API_PASSWORD

# ============================================
# TMUX Codeman (option with `cld --tmux-codeman`)
# ============================================
CODEMAN_USERNAME=caveman
CODEMAN_PASSWORD=YOUR_LLM_DOCKER_API_PASSWORD
