#!/usr/bin/env python3
"""
cld-status — live status panel for running cld containers.

Polls every 5s and renders one row per cld container:
    <project>  CPU [▁▂▃▆█▇▆▅▃] 42.3%   MEM [████░░░░░░] 38.1%
               NET ↓  12.4 kB/s   ↑   3.1 kB/s

Footer:
    CHRM: 3   PLAY: 2

Containers are identified by the docker labels cld attaches at run-time:
    com.docker.compose.project=llm-docker
    llm-docker-project=<basename>

Usage:
    cld-status                  — interactive (Ctrl-C to quit)
    cld-status --interval 3     — poll every 3s instead of 5s
    cld-status --width 30       — sparkline width (default 24)
    NO_COLOR=1 cld-status       — strip ANSI

No external deps; stdlib only.
"""

from __future__ import annotations

import argparse
import datetime as _dt
import os
import shutil
import signal
import hashlib
import subprocess
import sys
import time
from collections import deque
from pathlib import Path
from typing import Optional


# ── tunables ──────────────────────────────────────────────────────────
SAMPLE_INTERVAL_S = 5            # how often to poll docker stats
HISTORY_SAMPLES = 60             # 60 × 5s = 5 min
SPARK_BLOCKS = "▁▂▃▄▅▆▇█"        # 8 levels
MEM_BAR_WIDTH = 10               # cells

# ── ANSI ──────────────────────────────────────────────────────────────
if os.environ.get("NO_COLOR"):
    P = R = D = RST = ""
    def _titlebar(text): return f"{text}\n"
else:
    P = "\033[1;35m"; R = "\033[31m"; D = "\033[2m"; RST = "\033[0m"
    def _titlebar(text):  # bright-blue chip, dark bold text, filled to edge
        return f"\033[48;5;39m\033[38;5;16;1m {text} \033[K\033[0m\n"

CLEAR = "\033[2J\033[H"

# Per-project color, deterministic from the name so a project keeps the same
# color across refreshes. Applied to the name + sparkline only (stats stay
# in their semantic colors). Red is reserved for errors, so it's not here.
if os.environ.get("NO_COLOR"):
    PALETTE: list[int] = []
else:
    # 24 visually distinct 256-color hues (no red — reserved for errors).
    PALETTE = [39, 208, 48, 141, 220, 45, 205, 112, 111, 215,
               33, 202, 118, 213, 87, 228, 154, 201, 123, 214,
               51, 165, 82, 209]


def _project_palette_index(name: str):
    """The 256-color index this project hashes to (None when NO_COLOR/empty)."""
    if not PALETTE or not name:
        return None
    return PALETTE[int(hashlib.md5(name.encode()).hexdigest(), 16) % len(PALETTE)]


def project_color(name: str) -> str:
    """Stable per-project ANSI color picked from PALETTE by hashing the name.
    md5 (not Python's randomized hash) keeps the choice consistent across runs
    and spreads short names evenly. Empty string when NO_COLOR or no name."""
    idx = _project_palette_index(name)
    return f"\033[38;5;{idx}m" if idx is not None else ""


def _xterm256_rgb(idx: int) -> tuple:
    """xterm 256-color index → (r, g, b). PALETTE uses only the 16-231 color
    cube; the 232-255 grey ramp is handled too for completeness."""
    if idx >= 232:
        v = 8 + 10 * (idx - 232)
        return (v, v, v)
    i = idx - 16
    levels = (0, 95, 135, 175, 215, 255)
    return (levels[i // 36], levels[(i // 6) % 6], levels[i % 6])


def iterm_tab_color(name: str) -> str:
    """iTerm2 tab-color control sequences tinting the tab with the project's
    own hue (same one cld-status uses) — so the main Claude pane is always
    color-coded by project. Empty string when NO_COLOR / unknown."""
    idx = _project_palette_index(name)
    if idx is None:
        return ""
    r, g, b = _xterm256_rgb(idx)
    esc = "\033]6;1;bg;{};brightness;{}\a"
    return esc.format("red", r) + esc.format("green", g) + esc.format("blue", b)


# ── docker introspection ──────────────────────────────────────────────
def list_cld_containers() -> list[tuple[str, str, str]]:
    """Return [(container_id, project_name, started_at_iso), …] for running cld containers."""
    try:
        out = subprocess.run(
            [
                "docker", "ps",
                "--filter", "label=com.docker.compose.project=llm-docker",
                "--format", "{{.ID}}\t{{.Labels}}\t{{.CreatedAt}}",
            ],
            capture_output=True, text=True, timeout=4,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []
    containers: list[tuple[str, str, str]] = []
    for line in out.stdout.strip().splitlines():
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        cid, labels, created_at = parts[0], parts[1], parts[2]
        project = "unknown"
        for kv in labels.split(","):
            if kv.startswith("llm-docker-project="):
                project = kv.split("=", 1)[1] or "unknown"
                break
        containers.append((cid, project, created_at))
    return containers


def fmt_uptime(created_at: str) -> str:
    """`docker ps --format {{.CreatedAt}}` returns local-tz strings like
    '2026-06-19 04:12:55 -0700 PDT'. Compute now-then in compact h/m form."""
    # Strip trailing tz abbrev (e.g. ' PDT') so strptime can handle the offset.
    s = created_at.rsplit(" ", 1)[0]
    try:
        then = _dt.datetime.strptime(s, "%Y-%m-%d %H:%M:%S %z")
    except ValueError:
        return "?"
    delta = _dt.datetime.now(_dt.timezone.utc) - then.astimezone(_dt.timezone.utc)
    total_s = max(0, int(delta.total_seconds()))
    if total_s < 60:
        return f"{total_s}s"
    if total_s < 3600:
        return f"{total_s // 60}m"
    h, rem = divmod(total_s, 3600)
    m = rem // 60
    return f"{h}h{m:02d}m"


# Bind-mount used by cld: ~/.llm-docker/claude/.claude → /root/.claude inside
# the container. Claude Code writes its session transcripts to
# /root/.claude/projects/-root-Projects-<name>/<uuid>.jsonl, so on the host
# (where cld-status runs) the same file is reachable via:
#   ~/.llm-docker/claude/.claude/projects/-root-Projects-<name>/<uuid>.jsonl
_CLAUDE_SESSIONS_ROOT = Path.home() / ".llm-docker/claude/.claude/projects"


def claude_ctx_size(project_name: str) -> tuple[int, str]:
    """Return (bytes, session_id_short) for the most recently written Claude
    session transcript belonging to this project. Returns (0, '') if no
    session is found. The byte count is a proxy for context usage — actual
    tokens are ~bytes/4 but post-compaction the model sees less than what
    the file holds; treat it as 'work done', not 'tokens in window'."""
    if not _CLAUDE_SESSIONS_ROOT.is_dir():
        return (0, "")
    project_dir = _CLAUDE_SESSIONS_ROOT / f"-root-Projects-{project_name}"
    if not project_dir.is_dir():
        return (0, "")
    try:
        sessions = sorted(
            project_dir.glob("*.jsonl"),
            key=lambda p: p.stat().st_mtime,
            reverse=True,
        )
    except OSError:
        return (0, "")
    if not sessions:
        return (0, "")
    latest = sessions[0]
    try:
        size = latest.stat().st_size
    except OSError:
        return (0, "")
    return (size, latest.stem[:8])


def fmt_bytes(b: float) -> str:
    if b < 1024:
        return f"{b:4.0f} B"
    if b < 1024 * 1024:
        return f"{b / 1024:5.1f}KB"
    return f"{b / 1024 / 1024:5.1f}MB"


def docker_stats(container_ids: list[str]) -> dict[str, dict]:
    """One-shot `docker stats` for the given container IDs."""
    if not container_ids:
        return {}
    try:
        out = subprocess.run(
            [
                "docker", "stats", "--no-stream",
                "--format",
                "{{.ID}}\t{{.CPUPerc}}\t{{.MemPerc}}\t{{.NetIO}}\t{{.PIDs}}",
                *container_ids,
            ],
            capture_output=True, text=True, timeout=8,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return {}
    result: dict[str, dict] = {}
    for line in out.stdout.strip().splitlines():
        parts = line.split("\t")
        if len(parts) < 5:
            continue
        cid_short, cpu_s, mem_s, net_s, pids_s = parts[:5]
        try:
            pids = int(pids_s)
        except ValueError:
            pids = 0
        result[cid_short] = {
            "cpu": _parse_pct(cpu_s),
            "mem": _parse_pct(mem_s),
            "net_rx": _parse_bytes(net_s.split("/")[0].strip()),
            "net_tx": _parse_bytes(net_s.split("/")[1].strip())
            if "/" in net_s else 0,
            "pids": pids,
        }
    return result


def _parse_pct(s: str) -> float:
    try:
        return float(s.strip().rstrip("%"))
    except ValueError:
        return 0.0


def _parse_bytes(s: str) -> float:
    """`1.23kB` / `4.5MiB` → bytes float."""
    s = s.strip()
    units = [
        ("GiB", 1024 ** 3), ("MiB", 1024 ** 2), ("KiB", 1024),
        ("GB", 1e9), ("MB", 1e6), ("kB", 1e3), ("B", 1),
    ]
    for unit, mult in units:
        if s.endswith(unit):
            try:
                return float(s[: -len(unit)]) * mult
            except ValueError:
                return 0.0
    return 0.0


def count_processes(needle: str) -> int:
    """Count running processes whose argv contains `needle`. Quietly returns 0
    when pgrep is absent (Linux without procps, etc.)."""
    try:
        out = subprocess.run(
            ["pgrep", "-f", needle],
            capture_output=True, text=True, timeout=2,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return 0
    if out.returncode != 0:
        return 0
    return len([ln for ln in out.stdout.strip().splitlines() if ln])


# ── rendering ─────────────────────────────────────────────────────────
def sparkline(values: list[float], width: int) -> str:
    if not values:
        return " " * width
    tail = values[-width:]
    lo = min(tail)
    hi = max(tail)
    span = hi - lo
    if span < 1e-9:
        span = 1.0
    chars: list[str] = []
    for v in tail:
        idx = int((v - lo) / span * (len(SPARK_BLOCKS) - 1))
        idx = max(0, min(len(SPARK_BLOCKS) - 1, idx))
        chars.append(SPARK_BLOCKS[idx])
    return " " * (width - len(chars)) + "".join(chars)


def mem_bar(mem_pct: float) -> str:
    filled = int(round(mem_pct / 100 * MEM_BAR_WIDTH))
    filled = max(0, min(MEM_BAR_WIDTH, filled))
    return "█" * filled + "░" * (MEM_BAR_WIDTH - filled)


def render(
    containers: list[tuple[str, str, str]],
    stats: dict[str, dict],
    history: dict[str, deque],
    chrm: int,
    play: int,
) -> str:
    """Compact two-lines-per-container render — fits a ~40-col × 15-row
    iTerm split (1 header + 2*N container lines + 1 footer = 8 lines
    for 3 containers; up to 6 containers fits in 14)."""
    # Sparkline STRETCHES to the current pane width: total minus the fixed
    # prefix ("proj:<11" + space = 12) and the stats suffix
    # (" NNN% mNNN%" = 13). Recomputed every render so it tracks resizes.
    cols = shutil.get_terminal_size((40, 20)).columns
    spark_width = max(8, cols - 25)
    out: list[str] = []
    out.append(_titlebar(f"cld · status · {time.strftime('%H:%M:%S')}"))
    if not containers:
        out.append(f"{D}  no cld containers running{RST}\n")
    for cid, proj, created_at in containers:
        cid_short = cid[:12]
        s = stats.get(cid_short, {"cpu": 0.0, "mem": 0.0,
                                  "net_rx_rate": 0.0, "net_tx_rate": 0.0,
                                  "pids": 0})
        spark = sparkline(list(history.get(cid, deque())), spark_width)
        cpu = s.get("cpu", 0.0)
        mem = s.get("mem", 0.0)
        rx_kb = s.get("net_rx_rate", 0.0) / 1024
        tx_kb = s.get("net_tx_rate", 0.0) / 1024
        pids = s.get("pids", 0)
        uptime = fmt_uptime(created_at)
        ctx_bytes, _sess = claude_ctx_size(proj)
        ctx_short = fmt_bytes(ctx_bytes) if ctx_bytes else "—"
        # Line 1: project + sparkline (both in the project's own color) + cpu% + mem%
        col = project_color(proj)
        out.append(
            f"{col}{proj:<11}{RST} {col}{spark}{RST} "
            f"{cpu:4.0f}% {D}m{RST}{mem:4.0f}%\n"
        )
        # Line 2: net + up + pids + ctx (all dim labels)
        out.append(
            f"  {D}↓{RST}{rx_kb:4.0f} {D}↑{RST}{tx_kb:4.0f}kB/s "
            f"{D}up{RST}{uptime:<5} {D}p{RST}{pids:<3} "
            f"{D}ctx{RST} {ctx_short}\n"
        )
    out.append(
        f"{D}chrm{RST} {P}{chrm}{RST}  {D}play{RST} {P}{play}{RST}\n"
    )
    return "".join(out)


def resize_iterm_pane(rows: int) -> bool:
    """Resize the iTerm pane this script is running in. No-op outside
    iTerm. Returns True if the resize was dispatched (regardless of
    whether iTerm accepted it)."""
    session_id = os.environ.get("ITERM_SESSION_ID")
    if not session_id:
        return False
    script = f'''
    tell application "iTerm"
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    try
                        if id of s is "{session_id}" then
                            set rows of s to {rows}
                            return
                        end if
                    end try
                end repeat
            end repeat
        end repeat
    end tell
    '''
    try:
        subprocess.run(
            ["osascript", "-e", script],
            timeout=2, capture_output=True,
        )
        return True
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


# ── main loop ─────────────────────────────────────────────────────────
def main(argv: Optional[list[str]] = None) -> int:
    ap = argparse.ArgumentParser(
        description="Live status panel for running cld containers.",
    )
    ap.add_argument("--interval", type=float, default=SAMPLE_INTERVAL_S,
                    help="poll interval in seconds (default 5)")
    ap.add_argument("--tab-color", metavar="PROJECT",
                    help="print the iTerm tab-color escape for PROJECT and exit")
    args = ap.parse_args(argv)

    if args.tab_color is not None:
        sys.stdout.write(iterm_tab_color(args.tab_color))
        sys.stdout.flush()
        return 0

    if shutil.which("docker") is None:
        sys.stderr.write(f"{R}cld-status: docker not on PATH{RST}\n")
        return 2

    # Per-container history: cpu samples + previous net counters (for rates).
    cpu_history: dict[str, deque] = {}
    last_net: dict[str, dict] = {}    # cid -> {rx, tx, ts}
    last_rows = 0                     # last iTerm pane height we set

    def _exit(_signum, _frame):
        sys.stdout.write(f"\n{D}cld-status: exiting{RST}\n")
        sys.stdout.flush()
        sys.exit(0)

    signal.signal(signal.SIGINT, _exit)
    signal.signal(signal.SIGTERM, _exit)

    # Clear screen + scrollback once on start so the pane begins clean (the
    # per-render CLEAR below only wipes the visible screen, not scrollback).
    sys.stdout.write("\033[2J\033[3J\033[H")
    sys.stdout.flush()

    while True:
        containers = list_cld_containers()
        ids = [c[0] for c in containers]
        stats = docker_stats(ids)
        now = time.time()
        chrm = count_processes("chromium") or count_processes("chrome")
        play = count_processes("playwright")

        # Derive net rates per container; update cpu history.
        for cid, _proj, _created in containers:
            cid_short = cid[:12]
            s = stats.get(cid_short)
            if s is None:
                continue
            hist = cpu_history.setdefault(cid, deque(maxlen=HISTORY_SAMPLES))
            hist.append(s["cpu"])

            prev = last_net.get(cid)
            if prev is not None:
                dt = max(now - prev["ts"], 1e-3)
                s["net_rx_rate"] = max(0.0, (s["net_rx"] - prev["rx"]) / dt)
                s["net_tx_rate"] = max(0.0, (s["net_tx"] - prev["tx"]) / dt)
            else:
                s["net_rx_rate"] = 0.0
                s["net_tx_rate"] = 0.0
            last_net[cid] = {"rx": s["net_rx"], "tx": s["net_tx"], "ts": now}

        # Evict history for containers that disappeared.
        alive = {cid for cid, _proj, _created in containers}
        for dead in [k for k in cpu_history if k not in alive]:
            cpu_history.pop(dead, None)
            last_net.pop(dead, None)

        rendered = render(
            containers, stats, cpu_history, chrm, play
        )
        sys.stdout.write(CLEAR + rendered)
        sys.stdout.flush()

        # Auto-resize the iTerm pane to fit what we just rendered.
        # +1 buffer row for breathing space. No-op when not in iTerm.
        needed_rows = rendered.count("\n") + 1
        if needed_rows != last_rows:
            if resize_iterm_pane(needed_rows):
                last_rows = needed_rows

        time.sleep(args.interval)


if __name__ == "__main__":
    sys.exit(main() or 0)
