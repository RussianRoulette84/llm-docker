Port 666

HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ecdsa_key
HostKey /etc/ssh/ssh_host_ed25519_key

PermitRootLogin prohibit-password
PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no
UsePAM no

# Disable sshd's internal seccomp sandbox (incompatible with Docker containers)
UseDNS no
X11Forwarding no
PrintMotd no
AcceptEnv LANG LC_*

# NOTE: AllowUsers removed — Docker Desktop for Mac uses unpredictable source IPs
# Security is handled by: key-only auth (no passwords) + port binding
